# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API Secret (shared with Vercel frontend)
API_SECRET=your-random-secret-here

# LLM Provider — choose one:

# Option 1: DeepSeek (default, cheapest, good Chinese support)
DEEPSEEK_API_KEY=your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Option 2: OpenAI
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_VISION_MODEL=gpt-4o  # for image/receipt recognition

# Option 3: Anthropic Claude
# LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=https://api.anthropic.com/v1/
# LLM_MODEL=claude-sonnet-4-20250514

# Option 4: Ollama (local, private, no data leaves your device)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1:8b
# Note: Ollama does not support tool/function calling well.
# Best for simple chat, not recommended for full Apple capabilities.

# Option 5: Groq (fast inference)
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# Vision model (for receipt/business card recognition)
# Falls back to LLM_MODEL if not set
# LLM_VISION_MODEL=gpt-4o

# Server
PORT=3001

# Sessions storage path (Railway persistent volume)
SESSIONS_PATH=/data/.wa-sessions

# Web app URL (for email send integration)
WEB_APP_URL=http://localhost:3000
